# ──────────────────────────────────────────────
# Vercel Function (api/send.ts) で使う環境変数
# ──────────────────────────────────────────────

# Discord Botのトークン
# Developer Portal → アプリ → Bot → Reset Token で取得
DISCORD_BOT_TOKEN=MTIzNDU2Nzg5MA.Gabcde.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 送信先ユーザー(お母様)のDiscord User ID
# Discord開発者モードON → メンバーリストでお母様を右クリック → IDをコピー
DISCORD_RECIPIENT_USER_ID=123456789012345678

# PWA → APIの簡易認証用トークン
# PowerShell: -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Maximum 16) })
SHARED_TOKEN=ここに長いランダム文字列(64文字程度)を生成して貼る

# ──────────────────────────────────────────────
# フロントエンド(Vite)で使う環境変数
# ビルド時にバンドルに埋め込まれる前提
# ──────────────────────────────────────────────

# 上の SHARED_TOKEN と同じ値を入れる
VITE_SHARED_TOKEN=ここに長いランダム文字列(64文字程度)を生成して貼る
